<project>
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.github.josephkelly31</groupId>
  <artifactId>big-net</artifactId>
  <version>0.1.0</version>

  <properties>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
  </properties>

<build>
  <plugins>
    <plugin>
      <groupId>org.apache.maven.plugins</groupId>
      <artifactId>maven-jar-plugin</artifactId>  
      <configuration>
        <archive>
          <manifest>
            <mainClass>io.github.josephkelly31.App</mainClass>
          </manifest>
        </archive>
      </configuration>
    </plugin>
  </plugins>
</build>

</project>